# Docker MCP Gateway Demo — Environment Variables
# Copy this file to .env and fill in your keys

# GitHub Personal Access Token (optional for public repos)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Jira / Atlassian credentials
# Create API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_api_token_here

# ─── LLM Configuration ───────────────────────────────────────────────────────
# Enter your free Google AI Studio Key (Gemini) here:
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Or use OpenAI / compatible providers:
# OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"
# LLM_MODEL="gemini-2.5-flash"

# ─── Google Sheets MCP Server (NON-SECRET) ──────────────────────────────────
# Absolute path to the service account json on your host.
# Default (if unset): <project_root>/service_account.json
# GOOGLE_SHEETS_SERVICE_ACCOUNT_PATH="/absolute/path/to/service_account.json"

